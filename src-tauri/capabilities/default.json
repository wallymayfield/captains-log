{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for Captain's Log: file open/save and native dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.config/**" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.netrc" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.config/**" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.netrc" }
      ]
    }
  ]
}
